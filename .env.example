# MediSphere AI - Environment Variables
# Built by Zarak Khan
# 
# 1. Copy this file and rename it to .env
# 2. Fill in your actual API keys below
# 3. NEVER share .env file with anyone!

# Grok API Key (xAI) - Get free key from https://x.ai
GROK_API_KEY=your_grok_api_key_here

# Flask Secret Key (generate random string)
FLASK_SECRET_KEY=your_random_secret_key_here

# Hospital Name
HOSPITAL_NAME=Quetta City Hospital
HOSPITAL_ADDRESS=Jinnah Road, Near Serena Chowk, Quetta
HOSPITAL_PHONE=081-9201234

# Debug Mode (set to False for production)
DEBUG=True